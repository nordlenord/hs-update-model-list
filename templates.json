    "id": "meeting-notes",
    "version": 2,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Meeting Notes</title>\n  <style>\n    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; max-width: 760px; margin: 2rem auto; padding: 0 1.5rem; color: #1a1a2e; line-height: 1.6; }\n    h1 { font-size: 1.8rem; border-bottom: 3px solid #4361ee; padding-bottom: 0.4rem; margin-bottom: 0.3rem; }\n    .meta { color: #555; font-size: 0.95rem; margin-bottom: 1.5rem; }\n    .meta span { margin-right: 1.5rem; }\n    h2 { font-size: 1.15rem; color: #4361ee; margin-top: 1.8rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.04em; }\n    ul, ol { padding-left: 1.4rem; }\n    li { margin-bottom: 0.35rem; }\n    table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }\n    th { background: #4361ee; color: #fff; text-align: left; padding: 0.5rem 0.75rem; font-weight: 600; font-size: 0.9rem; }\n    td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #e0e0e0; }\n    tr:hover td { background: #f0f4ff; }\n    .badge { display: inline-block; background: #e8edff; color: #4361ee; padding: 0.15rem 0.6rem; border-radius: 12px; font-size: 0.8rem; font-weight: 600; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"meta\">\n    <span>📅 {{date}}</span>\n    <span>👤 {{author}}</span>\n    <span class=\"badge\">Meeting</span>\n  </div>\n\n  <h2>Attendees</h2>\n  <p></p>\n\n  <h2>Agenda</h2>\n  <ol>\n    <li></li>\n    <li></li>\n    <li></li>\n  </ol>\n\n  <h2>Discussion</h2>\n  <p></p>\n\n  <h2>Action Items</h2>\n  <table>\n    <thead>\n      <tr><th>Task</th><th>Owner</th><th>Due</th><th>Status</th></tr>\n    </thead>\n    <tbody>\n      <tr><td></td><td></td><td></td><td></td></tr>\n      <tr><td></td><td></td><td></td><td></td></tr>\n    </tbody>\n  </table>\n\n  <h2>Next Steps</h2>\n  <ul>\n    <li></li>\n  </ul>\n</body>\n</html>\n"
