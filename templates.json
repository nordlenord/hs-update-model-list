    "id": "research-note",
    "version": 2,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Research Note</title>\n  <style>\n    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; max-width: 740px; margin: 2rem auto; padding: 0 1.5rem; color: #1a1a2e; line-height: 1.65; }\n    h1 { font-size: 1.8rem; border-bottom: 3px solid #2d6a4f; padding-bottom: 0.4rem; }\n    .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }\n    h2 { font-size: 1.1rem; color: #2d6a4f; margin-top: 1.8rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.04em; }\n    .source-box { background: #f0f7f4; border-left: 4px solid #2d6a4f; padding: 0.8rem 1rem; border-radius: 0 6px 6px 0; margin: 0.5rem 0 1.2rem; }\n    .source-box p { margin: 0.2rem 0; font-size: 0.95rem; }\n    ul { padding-left: 1.4rem; }\n    li { margin-bottom: 0.4rem; }\n    blockquote { border-left: 3px solid #95d5b2; margin: 1rem 0; padding: 0.5rem 1rem; background: #f0f7f4; color: #2d4a3e; font-style: italic; border-radius: 0 4px 4px 0; }\n    .tag { display: inline-block; background: #d8f3dc; color: #2d6a4f; padding: 0.1rem 0.55rem; border-radius: 10px; font-size: 0.8rem; margin-right: 0.3rem; font-weight: 600; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"meta\">📅 {{date}} · {{author}}</div>\n\n  <h2>Source</h2>\n  <div class=\"source-box\">\n    <p><strong>URL / Reference:</strong> </p>\n    <p><strong>Author / Publisher:</strong> </p>\n    <p><strong>Date Published:</strong> </p>\n  </div>\n\n  <h2>Summary</h2>\n  <p></p>\n\n  <h2>Key Findings</h2>\n  <ul>\n    <li></li>\n    <li></li>\n    <li></li>\n  </ul>\n\n  <h2>Notable Quotes</h2>\n  <blockquote></blockquote>\n\n  <h2>Analysis &amp; Thoughts</h2>\n  <p></p>\n\n  <h2>Related Topics</h2>\n  <p><span class=\"tag\"></span></p>\n</body>\n</html>\n"
  },
  {
    "id": "weekly-review",
    "version": 1,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Weekly Review</title>\n  <style>\n    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1.5rem; color: #1a1a2e; line-height: 1.65; }\n    h1 { font-size: 1.8rem; border-bottom: 3px solid #e76f51; padding-bottom: 0.4rem; }\n    .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }\n    h2 { font-size: 1.1rem; color: #e76f51; margin-top: 1.8rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.04em; }\n    .progress-section { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.8rem; margin: 0.5rem 0 1rem; }\n    .progress-card { text-align: center; padding: 0.8rem; border-radius: 8px; }\n    .progress-card.done { background: #d8f3dc; color: #2d6a4f; }\n    .progress-card.wip { background: #fff3cd; color: #856404; }\n    .progress-card.blocked { background: #fde8e8; color: #c0392b; }\n    .progress-card .number { font-size: 1.6rem; font-weight: 700; }\n    .progress-card .label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }\n    ul { padding-left: 1.4rem; }\n    li { margin-bottom: 0.4rem; }\n    .rating { font-size: 1.2rem; letter-spacing: 0.15em; }\n    hr { border: none; border-top: 1px solid #eee; margin: 1.5rem 0; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"meta\">Week of {{date}} · {{author}}</div>\n\n  <h2>Progress Snapshot</h2>\n  <div class=\"progress-section\">\n    <div class=\"progress-card done\"><div class=\"number\">0</div><div class=\"label\">Completed</div></div>\n    <div class=\"progress-card wip\"><div class=\"number\">0</div><div class=\"label\">In Progress</div></div>\n    <div class=\"progress-card blocked\"><div class=\"number\">0</div><div class=\"label\">Blocked</div></div>\n  </div>\n\n  <h2>Accomplishments</h2>\n  <ul>\n    <li></li>\n    <li></li>\n  </ul>\n\n  <h2>Challenges</h2>\n  <ul>\n    <li></li>\n  </ul>\n\n  <h2>Lessons Learned</h2>\n  <p></p>\n\n  <hr>\n\n  <h2>Next Week's Priorities</h2>\n  <ol>\n    <li></li>\n    <li></li>\n    <li></li>\n  </ol>\n\n  <h2>Overall Rating</h2>\n  <p class=\"rating\">☆☆☆☆☆</p>\n</body>\n</html>\n"
  },
  {
    "id": "decision-log",
    "version": 1,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Decision Log</title>\n  <style>\n    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; max-width: 740px; margin: 2rem auto; padding: 0 1.5rem; color: #1a1a2e; line-height: 1.65; }\n    h1 { font-size: 1.8rem; border-bottom: 3px solid #e63946; padding-bottom: 0.4rem; }\n    .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }\n    h2 { font-size: 1.1rem; color: #e63946; margin-top: 1.8rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.04em; }\n    .decision-box { background: #fff5f5; border: 2px solid #e63946; border-radius: 8px; padding: 1rem 1.2rem; margin: 0.8rem 0 1.5rem; font-size: 1.05rem; font-weight: 500; }\n    .option { background: #f8f9fa; border-radius: 6px; padding: 0.8rem 1rem; margin-bottom: 0.6rem; }\n    .option-header { font-weight: 600; margin-bottom: 0.3rem; }\n    .pros { color: #2d6a4f; }\n    .cons { color: #c0392b; }\n    ul { padding-left: 1.4rem; margin: 0.3rem 0; }\n    li { margin-bottom: 0.25rem; font-size: 0.95rem; }\n    .impact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-top: 0.5rem; }\n    .impact-item { background: #f8f9fa; padding: 0.5rem 0.8rem; border-radius: 6px; font-size: 0.9rem; }\n    .impact-item strong { display: block; font-size: 0.75rem; text-transform: uppercase; color: #e63946; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"meta\">📅 {{date}} · Decision Maker: {{author}}</div>\n\n  <h2>Context</h2>\n  <p></p>\n\n  <h2>Decision</h2>\n  <div class=\"decision-box\"></div>\n\n  <h2>Options Considered</h2>\n  <div class=\"option\">\n    <div class=\"option-header\">Option A: </div>\n    <span class=\"pros\">Pros:</span>\n    <ul><li></li></ul>\n    <span class=\"cons\">Cons:</span>\n    <ul><li></li></ul>\n  </div>\n  <div class=\"option\">\n    <div class=\"option-header\">Option B: </div>\n    <span class=\"pros\">Pros:</span>\n    <ul><li></li></ul>\n    <span class=\"cons\">Cons:</span>\n    <ul><li></li></ul>\n  </div>\n\n  <h2>Expected Impact</h2>\n  <div class=\"impact-grid\">\n    <div class=\"impact-item\"><strong>Timeline</strong> </div>\n    <div class=\"impact-item\"><strong>Cost</strong> </div>\n    <div class=\"impact-item\"><strong>Risk Level</strong> </div>\n    <div class=\"impact-item\"><strong>Reversibility</strong> </div>\n  </div>\n\n  <h2>Follow-up</h2>\n  <ul>\n    <li></li>\n  </ul>\n</body>\n</html>\n"
  },
  {
    "id": "book-notes",
    "version": 1,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Book Notes</title>\n  <style>\n    body { font-family: 'Georgia', 'Times New Roman', serif; max-width: 700px; margin: 2rem auto; padding: 0 1.5rem; color: #2d2d2d; line-height: 1.7; }\n    h1 { font-size: 1.8rem; font-weight: 400; margin-bottom: 0.2rem; }\n    .book-meta { background: #f4f1eb; border-radius: 8px; padding: 1rem 1.2rem; margin-bottom: 1.8rem; }\n    .book-meta p { margin: 0.25rem 0; font-size: 0.95rem; color: #555; }\n    h2 { font-family: 'Segoe UI', system-ui, sans-serif; font-size: 1rem; color: #8b5e3c; margin-top: 1.8rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; }\n    .rating { font-size: 1.3rem; letter-spacing: 0.15em; margin: 0.3rem 0 1rem; }\n    blockquote { border-left: 3px solid #d4a574; margin: 0.8rem 0; padding: 0.4rem 1rem; color: #6b4e2e; font-style: italic; background: #fdf8f3; }\n    ul { padding-left: 1.3rem; }\n    li { margin-bottom: 0.4rem; }\n    .tag { display: inline-block; background: #f4e8d9; color: #8b5e3c; padding: 0.1rem 0.55rem; border-radius: 10px; font-size: 0.8rem; font-family: 'Segoe UI', sans-serif; margin-right: 0.3rem; font-weight: 600; }\n    hr { border: none; border-top: 1px solid #e8dcc8; margin: 1.5rem 0; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"book-meta\">\n    <p><strong>Author:</strong> </p>\n    <p><strong>Published:</strong> </p>\n    <p><strong>Genre:</strong> </p>\n    <p><strong>Read Date:</strong> {{date}}</p>\n  </div>\n\n  <h2>Rating</h2>\n  <p class=\"rating\">☆☆☆☆☆</p>\n\n  <h2>One-Sentence Summary</h2>\n  <p></p>\n\n  <h2>Key Takeaways</h2>\n  <ul>\n    <li></li>\n    <li></li>\n    <li></li>\n  </ul>\n\n  <h2>Favorite Quotes</h2>\n  <blockquote></blockquote>\n\n  <hr>\n\n  <h2>How It Changed My Thinking</h2>\n  <p></p>\n\n  <h2>Who Should Read This</h2>\n  <p></p>\n\n  <h2>Tags</h2>\n  <p><span class=\"tag\"></span></p>\n</body>\n</html>\n"
  },
