  {
    "id": "daily-journal",
    "version": 2,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Daily Journal</title>\n  <style>\n    body { font-family: 'Georgia', 'Times New Roman', serif; max-width: 680px; margin: 2rem auto; padding: 0 1.5rem; color: #2d2d2d; line-height: 1.75; background: #fffcf7; }\n    h1 { font-size: 1.8rem; font-weight: 400; border-bottom: 2px solid #c9a96e; padding-bottom: 0.4rem; color: #5c4b2a; }\n    .meta { color: #8a7a5a; font-size: 0.9rem; margin-bottom: 1.8rem; font-style: italic; }\n    h2 { font-size: 1.1rem; color: #c9a96e; margin-top: 1.8rem; margin-bottom: 0.4rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }\n    .mood-row { display: flex; gap: 2rem; margin: 0.5rem 0 1rem; }\n    .mood-item { font-size: 0.95rem; }\n    ul { padding-left: 1.2rem; list-style: '✦ '; }\n    li { margin-bottom: 0.4rem; }\n    blockquote { border-left: 3px solid #c9a96e; margin: 1rem 0; padding: 0.5rem 1rem; color: #6b5d3f; font-style: italic; background: #fff8ec; }\n    hr { border: none; border-top: 1px solid #e8dcc8; margin: 2rem 0; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"meta\">{{date}} · {{datetime}} · {{author}}</div>\n\n  <h2>Mood &amp; Energy</h2>\n  <div class=\"mood-row\">\n    <span class=\"mood-item\">Mood: &nbsp;&nbsp;&nbsp;</span>\n    <span class=\"mood-item\">Energy: &nbsp;&nbsp;&nbsp;</span>\n    <span class=\"mood-item\">Sleep: &nbsp;&nbsp;&nbsp;</span>\n  </div>\n\n  <h2>Gratitude</h2>\n  <ul>\n    <li></li>\n    <li></li>\n    <li></li>\n  </ul>\n\n  <h2>Today's Highlights</h2>\n  <p></p>\n\n  <h2>Reflections</h2>\n  <p></p>\n\n  <hr>\n\n  <h2>Free Writing</h2>\n  <p></p>\n</body>\n</html>\n"
  },
  {
    "id": "project-plan",
    "version": 1,
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Project Plan</title>\n  <style>\n    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; max-width: 780px; margin: 2rem auto; padding: 0 1.5rem; color: #1a1a2e; line-height: 1.6; }\n    h1 { font-size: 1.8rem; margin-bottom: 0.2rem; }\n    .subtitle { color: #666; font-size: 1rem; margin-bottom: 1.5rem; }\n    h2 { font-size: 1.15rem; color: #7209b7; margin-top: 2rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.04em; border-left: 4px solid #7209b7; padding-left: 0.6rem; }\n    table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }\n    th { background: #7209b7; color: #fff; text-align: left; padding: 0.5rem 0.75rem; font-weight: 600; font-size: 0.9rem; }\n    td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #e0e0e0; }\n    .status-badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 10px; font-size: 0.8rem; font-weight: 600; }\n    .overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin: 0.5rem 0; }\n    .overview-item { background: #f8f0ff; padding: 0.6rem 1rem; border-radius: 6px; }\n    .overview-item strong { color: #7209b7; display: block; font-size: 0.8rem; text-transform: uppercase; }\n    ul { padding-left: 1.4rem; }\n    li { margin-bottom: 0.35rem; }\n  </style>\n</head>\n<body>\n  <h1>{{title}}</h1>\n  <div class=\"subtitle\">Created {{date}} by {{author}}</div>\n\n  <h2>Overview</h2>\n  <div class=\"overview-grid\">\n    <div class=\"overview-item\"><strong>Start Date</strong> </div>\n    <div class=\"overview-item\"><strong>Target Date</strong> </div>\n    <div class=\"overview-item\"><strong>Status</strong> </div>\n    <div class=\"overview-item\"><strong>Priority</strong> </div>\n  </div>\n\n  <h2>Objective</h2>\n  <p></p>\n\n  <h2>Scope</h2>\n  <ul>\n    <li></li>\n    <li></li>\n  </ul>\n\n  <h2>Milestones</h2>\n  <table>\n    <thead>\n      <tr><th>Milestone</th><th>Target Date</th><th>Status</th></tr>\n    </thead>\n    <tbody>\n      <tr><td></td><td></td><td></td></tr>\n      <tr><td></td><td></td><td></td></tr>\n      <tr><td></td><td></td><td></td></tr>\n    </tbody>\n  </table>\n\n  <h2>Risks &amp; Dependencies</h2>\n  <ul>\n    <li></li>\n  </ul>\n\n  <h2>Notes</h2>\n  <p></p>\n</body>\n</html>\n"
